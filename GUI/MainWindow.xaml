<Window x:Class="LINE.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LINE - Line is Not an Emulator" 
        Height="800" Width="1200"
        Background="#1e1e1e"
        Foreground="#ffffff"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2d2d2d" BorderBrush="#0078d4" BorderThickness="0,0,0,2" Padding="20">
            <StackPanel>
                <TextBlock Text="🚀 LINE - Line is Not an Emulator" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="#0078d4" Margin="0,0,0,5"/>
                <TextBlock Text="Wine inversé pour exécuter du Linux sur Windows (sans WSL ni Admin)" 
                           FontSize="12" Foreground="#a0a0a0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Actions -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="15">
                
                <!-- Install Section -->
                <Border Background="#2d2d2d" BorderBrush="#0078d4" BorderThickness="1" CornerRadius="5" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="📦 Installer un package" FontSize="14" FontWeight="Bold" Foreground="#0078d4"/>
                        
                        <TextBlock Text="Sélectionner un fichier:" FontSize="11" Foreground="#a0a0a0"/>
                        <TextBox x:Name="FilePathTextBox" 
                                 Background="#1e1e1e" 
                                 Foreground="#ffffff"
                                 Padding="10" 
                                 Height="35"
                                 IsReadOnly="True"/>
                        
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" 
                                    Content="Parcourir..." 
                                    Click="BrowseButton_Click"
                                    Background="#0078d4" Foreground="white"
                                    Padding="10" FontWeight="Bold"
                                    Cursor="Hand"/>
                            
                            <Button Grid.Column="1" 
                                    Content="Installer" 
                                    Click="InstallButton_Click"
                                    Background="#28a745" Foreground="white"
                                    Padding="10" FontWeight="Bold"
                                    Cursor="Hand"/>
                        </Grid>

                        <TextBlock x:Name="InstallStatus" 
                                   Text="Prêt" 
                                   FontSize="10" Foreground="#90EE90"
                                   TextWrapping="Wrap" MinHeight="40"/>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Background="#2d2d2d" BorderBrush="#0078d4" BorderThickness="1" CornerRadius="5" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="⚡ Actions rapides" FontSize="14" FontWeight="Bold" Foreground="#0078d4"/>
                        
                        <Button Content="🔄 Rafraîchir" 
                                Click="RefreshButton_Click"
                                Background="#0078d4" Foreground="white"
                                Padding="10" FontWeight="Bold"
                                Cursor="Hand"/>
                        
                        <Button Content="📁 Ouvrir le dossier" 
                                Click="OpenFolderButton_Click"
                                Background="#17a2b8" Foreground="white"
                                Padding="10" FontWeight="Bold"
                                Cursor="Hand"/>
                        
                        <Button Content="🗑️  Nettoyer le cache" 
                                Click="CleanCacheButton_Click"
                                Background="#fd7e14" Foreground="white"
                                Padding="10" FontWeight="Bold"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Stats -->
                <Border Background="#2d2d2d" BorderBrush="#0078d4" BorderThickness="1" CornerRadius="5" Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="📊 Statistiques" FontSize="14" FontWeight="Bold" Foreground="#0078d4"/>
                        
                        <TextBlock>
                            <Run Text="Paquets: " Foreground="#a0a0a0"/>
                            <Run x:Name="PackageCountText" Text="0" Foreground="#0078d4" FontWeight="Bold"/>
                        </TextBlock>
                        
                        <TextBlock>
                            <Run Text=".deb: " Foreground="#a0a0a0"/>
                            <Run x:Name="DebCountText" Text="0" Foreground="#0078d4" FontWeight="Bold"/>
                        </TextBlock>
                        
                        <TextBlock>
                            <Run Text="AppImages: " Foreground="#a0a0a0"/>
                            <Run x:Name="AppImageCountText" Text="0" Foreground="#0078d4" FontWeight="Bold"/>
                        </TextBlock>
                        
                        <TextBlock>
                            <Run Text="Binaires: " Foreground="#a0a0a0"/>
                            <Run x:Name="BinaryCountText" Text="0" Foreground="#0078d4" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Right Panel - Package List -->
            <ListBox Grid.Column="1" 
                     x:Name="PackagesListBox"
                     Background="#1e1e1e" 
                     Foreground="#ffffff"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2d2d2d" Padding="15" Margin="0,5" CornerRadius="5"
                                BorderBrush="#0078d4" BorderThickness="1">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="#0078d4">
                                        <Run Text="{Binding Icon}"/><Run Text=" "/><Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Type}" 
                                               FontSize="10" Foreground="#a0a0a0" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding Path}" 
                                               FontSize="9" Foreground="#666666" Margin="0,3,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Content="▶️ Exécuter" 
                                        Click="RunPackageButton_Click"
                                        Background="#28a745" Foreground="white"
                                        Padding="8,5"
                                        Tag="{Binding Name}"
                                        Cursor="Hand"
                                        FontWeight="Bold"/>

                                <Button Grid.Column="2" 
                                        Content="🗑️ Supprimer" 
                                        Click="DeletePackageButton_Click"
                                        Background="#dc3545" Foreground="white"
                                        Padding="8,5"
                                        Tag="{Binding Name}"
                                        Cursor="Hand"
                                        FontWeight="Bold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#2d2d2d" BorderBrush="#0078d4" BorderThickness="0,2,0,0" Padding="20">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="LINE v0.1.0 Beta | Wine inversé pour Linux sur Windows | © 2026"
                           Foreground="#a0a0a0" FontSize="10"/>

                <TextBlock Grid.Column="1" 
                           Text="❌ Sans WSL • ❌ Sans Admin • ✓ Pur Windows"
                           Foreground="#0078d4" FontSize="10" FontWeight="Bold"/>
            </Grid>
        </Border>

    </Grid>
</Window>
